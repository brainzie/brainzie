@*
    Course 08 · Lesson 01 · EXERCISE
    A small interactive checkpoint. Students reproduce this in Visual Studio:
    a MyButton that drives state in C#. Goal: reach the target using either
    the mouse OR the keyboard, proving both activation paths work.
*@

<div class="exercise">
    <p class="goal">Goal: reach <strong>@target</strong> by clicking the button.</p>

    <div class="score">@count / @target</div>

    <MyButton OnClick="Add">Add one</MyButton>

    @if (count >= target)
    {
        <p class="win">🎉 You did it! Notice it worked with the mouse <em>and</em> the keyboard.</p>
    }

    <button class="reset" @onclick="Reset">Reset</button>
</div>

@code {
    private int count;
    private const int target = 5;

    private void Add() => count++;

    private void Reset() => count = 0;
}

<style>
    .exercise { display: flex; flex-direction: column; align-items: center; gap: 14px; text-align: center; }
    .goal { margin: 0; color: #4A4361; }
    .score { font-family: "Space Grotesk", system-ui, sans-serif; font-size: 2.4rem; font-weight: 700; color: #18122B; }
    .win { color: #6D28D9; font-weight: 600; margin: 4px 0 0; }
    .reset { background: none; border: 1px solid #ECE7F2; color: #847B9C; padding: 6px 14px; border-radius: 999px; cursor: pointer; font-family: inherit; font-size: .85rem; }
    .reset:hover { border-color: #D81B72; color: #A8155A; }
</style>
