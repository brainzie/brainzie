@*
    Course 08 · Lesson 01 · DEMO
    The finished MyButton component in action. Embedded in the lesson's final step.
    Try it with the mouse, and with the keyboard: Tab to it, then Enter or Space.
*@

<MyButton OnClick="OnClicked">Click me</MyButton>

<p style="min-height:1.5em; font-weight:600; color:#6D28D9; margin:0;">
    @message
</p>

@code {
    private string message = "";
    private int count;

    private void OnClicked()
    {
        count++;
        message = count == 1
            ? "Clicked! ✓  (1 time)"
            : $"Clicked! ✓  ({count} times)";
    }
}
